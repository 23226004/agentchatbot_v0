# OpenAI 호환 LLM 서버 (vLLM/TGI 등)
# 서버는 8000 또는 8080 포트에서 제공됨 — 경로 끝에 /v1 포함
LLM_BASE_URL=http://localhost:8000/v1
# LLM_BASE_URL=http://localhost:8080/v1

# 서버에 로드된 모델 이름 (필수)
LLM_MODEL=

# 자체 서버는 보통 더미값 사용
LLM_API_KEY=EMPTY

# 선택값
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=60
# 응답 토큰 상한(G3 출력 DoS 바운드 — content_md/summary/tool.call args 를 근원에서 제한). provider 별 분리:
#   GPT_MAX_TOKENS : GPT(openai). 미설정=None(OpenAI 모델 한도에 위임, 절대 절단 안 함). 명시 캡 원할 때만.
#   LLM_MAX_TOKENS : 로컬 호환서버. 미설정=8192(self-host 1차 캡, 16k thinking 여유). thinking 더 필요시 ↑. 0=무제한.
# GPT_MAX_TOKENS=
# LLM_MAX_TOKENS=8192
# LLM 관측(Langfuse self-host v3 — 토큰/비용/프롬프트·완성/ReAct 트레이스).
#   ★ HOST·PUBLIC·SECRET **셋 다** 설정해야 활성. 하나라도 빠지면 no-op(에이전트 무영향).
#   ★ HOST 필수(거버넌스): 빠지면 SDK 가 cloud.langfuse.com 폴백 → 법령데이터 유출이므로 코드가
#     HOST 누락/Cloud 호스트를 **활성 거부**(self-host 전용). 반드시 self-host HOST 명시.
#   띄우기: docker compose -f deploy/docker-compose.langfuse.yml --env-file deploy/.env.langfuse up -d
#   키 값 = deploy/.env.langfuse 의 LANGFUSE_INIT_PROJECT_PUBLIC/SECRET_KEY. UI http://localhost:3001
# LANGFUSE_HOST=http://localhost:3001
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
