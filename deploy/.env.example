# db-layer 런타임 엔드포인트 (Design v0.3.1 §7.2)

# ── 로컬 Docker (docker-compose.yml) ──
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=law
FUSEKI_ADMIN_PASSWORD=admin123
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=law_articles

# ── 원격(Tailscale) — 컨테이너 아님 ──
# REMOTE_HOST = 실제 임베딩/LLM 서버 주소(예: Tailscale IP)로 치환. 실주소는 deploy/.env·agent/.env 에만.
# BGE-m3 임베딩 (llama.cpp, dense 1024 only; sparse는 후속 FlagEmbedding)
# ★ EMBEDDING_BACKEND=remote 필수(기본 flag=로컬 torch/FlagEmbedding — 미설치 시 search_legal 이 조용히
#   "일시적 오류"로 실패). 리랭커도 torch 라 RERANK=0(원격 토폴로지). 로컬 torch 설치 시에만 flag/RERANK=1.
EMBEDDING_BACKEND=remote
RERANK=0
EMBEDDING_URL=http://REMOTE_HOST:8081/v1
EMBEDDING_MODEL=bge-m3
# v1 enhancement 예정
# RERANKER_URL=
# EMBEDDING_SPARSE_URL=   # FlagEmbedding 자체서버

# ── law.go.kr OpenAPI (기존) ──
# 실제 OC(법령정보 OpenAPI 신청 시 발급된 기관코드/ID)는 deploy/.env 또는 agent/.env 에만(gitignored).
LAW_API_OC=<your-law.go.kr-OC>

# ── conversation-store (슬라이스5 합성루트 부팅에 필수) ──
DATABASE_URL=postgresql://convstore:convstore@localhost:5434/convstore
# LLM (agent) — 최소 하나 필수. 여러 개 설정하면 **런타임에 모델 선택**(POST /messages {model}).
#   1) OpenAI(GPT): OPENAI_API + GPT_MODELS(콤마구분, 동시 다버전) 또는 GPT_MODEL(단수)
#   2) OpenAI 호환(자체서버): LLM_MODELS(콤마) 또는 LLM_MODEL (+ LLM_BASE_URL)
# 사용된 모델은 runs.model·messages.model(이력)·로그에 기록된다. GET /models 로 목록 노출.
# OPENAI_API=
# GPT_MODELS=gpt-5.4-nano-2026-03-17,gpt-5.4-mini-2026-03-17   # 동시 다버전
LLM_MODEL=qwen3.6-35b-a3b
LLM_BASE_URL=http://REMOTE_HOST:8080/v1
# 도구 실행 전 승인 게이트(/approve 활성화). 0=끔(기본), 1=켬.
REQUIRE_APPROVAL=0
# 응답 토큰 상한(G3 출력 DoS 바운드). provider 별 분리: GPT_MAX_TOKENS 미설정=None(OpenAI 한도 위임),
# LLM_MAX_TOKENS 미설정=8192(로컬 self-host 1차 캡; qwen thinking 더 필요시 ↑, 0=무제한).
# GPT_MAX_TOKENS=
# LLM_MAX_TOKENS=8192
# 요청 body 크기 상한(G3 body-DoS — 파싱 전 413). 기본 1MB.
# MAX_REQUEST_BYTES=1048576
# G6 관측성 로그 레벨(conversation.* 네임스페이스). 기본 INFO. 에러 경로는 진짜 예외를 서버 로그에 남김.
# LOG_LEVEL=INFO
# LLM 관측(Langfuse self-host — 토큰/비용/ReAct 트레이스). env 없으면 no-op(에이전트 무영향).
#   띄우기: docker compose -f deploy/docker-compose.langfuse.yml --env-file deploy/.env.langfuse up -d
#   키 값은 deploy/.env.langfuse(gitignored)의 INIT_PROJECT_PUBLIC/SECRET_KEY 와 동일. UI: http://localhost:3001
# LANGFUSE_HOST=http://localhost:3001
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# 내구 이벤트로그(run_events) 보존·정리(SSE 재연결용 임시로그 — transcript 는 영구). 종결된 지
# RETENTION 지난 run 의 이벤트를 GC_INTERVAL 마다 삭제. (기본: 7일 보존, 1시간 주기)
# RUN_EVENTS_RETENTION_S=604800
# RUN_EVENTS_GC_INTERVAL_S=3600
# (선택) DB 풀: DB_POOL_MAX=20  DB_POOL_MIN=2 / 스트림 폴링: RUN_STREAM_POLL_MS=150
